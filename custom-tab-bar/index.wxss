.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: calc(50rpx + env(safe-area-inset-bottom));
  background: #fff;
  display: flex;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 999;
}

.tab-bar-border {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 1rpx;
  background: rgba(0, 0, 0, 0.08);
}

.tab-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.tab-icon {
  font-size: 34rpx;
  color: #999;
  font-weight: 300;
  transition: color 0.2s;
  line-height: 1;
  margin-bottom: 4rpx;
}

.tab-text {
  font-size: 20rpx;
  color: #999;
  transition: color 0.2s;
}

.tab-icon.active,
.tab-text.active {
  color: #2c8f5e;
}

.tab-icon.active {
  font-weight: 600;
}
