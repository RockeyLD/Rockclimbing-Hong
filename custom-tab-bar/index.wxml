<cover-view class="tab-bar" wx:if="{{show}}">
  <cover-view class="tab-bar-border"></cover-view>
  <cover-view wx:for="{{list}}" wx:key="index" class="tab-bar-item" data-path="{{item.pagePath}}" data-index="{{index}}" data-nav="{{item.isNav}}" bindtap="switchTab">
    <cover-view class="tab-icon {{selected === index ? 'active' : ''}}">
      {{item.icon}}
    </cover-view>
    <cover-view class="tab-text {{selected === index ? 'active' : ''}}">{{item.text}}</cover-view>
  </cover-view>
</cover-view>
