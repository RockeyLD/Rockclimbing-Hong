page {
  height: 100vh;
  display: flex;
  flex-direction: column;
}
.scrollarea {
  flex: 1;
  overflow-y: hidden;
}
.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

.form-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.form-item {
  margin-bottom: 30rpx;
}
.form-item:last-child {
  margin-bottom: 0;
}

.label {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 16rpx;
}

/* 媒体上传 */
.media-upload {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.media-preview {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}
.preview-img {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
  background: #f0f0f0;
}
.delete-btn {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 40rpx;
  height: 40rpx;
  background: #e53935;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  line-height: 1;
}
.upload-btn {
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed #ccc;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #999;
}
.upload-icon {
  font-size: 48rpx;
  line-height: 1;
  margin-bottom: 8rpx;
}
.upload-text {
  font-size: 24rpx;
}

/* 描述 */
.desc-input {
  width: 100%;
  height: 200rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}
.char-count {
  display: block;
  text-align: right;
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 文本输入 */
.text-input {
  width: 100%;
  height: 80rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

/* 日期选择 */
.picker-value {
  width: 100%;
  height: 80rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  line-height: 80rpx;
  color: #333;
  box-sizing: border-box;
}

/* 类型选择 */
.type-selector {
  display: flex;
  gap: 20rpx;
}
.type-option {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background: #f0f0f0;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #666;
}
.type-option.selected {
  background: #2c8f5e;
  color: #fff;
}

.submit-btn {
  margin-top: 20rpx;
}
