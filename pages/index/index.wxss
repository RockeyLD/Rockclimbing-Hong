page {
  height: 100vh;
  display: flex;
  flex-direction: column;
}
.scrollarea {
  flex: 1;
  overflow-y: hidden;
}

/* 统计栏 */
.stats-bar {
  display: flex;
  justify-content: space-around;
  background: linear-gradient(135deg, #2c8f5e, #3daa73);
  border-radius: 16rpx;
  padding: 30rpx 0;
  margin-bottom: 20rpx;
}
.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.stat-num {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
}
.stat-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
}

/* 记录卡片 */
.record-card {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}
.card-header {
  padding: 24rpx 24rpx 16rpx;
}
.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #2c8f5e, #3daa73);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 500;
  margin-right: 16rpx;
}
.author-info {
  display: flex;
  flex-direction: column;
}
.author-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}
.post-time {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.card-content {
  padding: 0 24rpx 16rpx;
}
.content-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  display: block;
  margin-bottom: 16rpx;
}
.media-grid {
  position: relative;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8rpx;
  margin-bottom: 16rpx;
}
.media-img {
  width: 100%;
  height: 220rpx;
  border-radius: 8rpx;
  background: #f0f0f0;
}
.media-img.single {
  height: 400rpx;
  grid-column: span 3;
}
.video-badge {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: rgba(0, 0, 0, 0.6);
  color: #fff;
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
}
.location-tag {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #666;
}
.loc-icon {
  margin-right: 6rpx;
}

.card-footer {
  padding: 16rpx 24rpx;
  border-top: 1rpx solid #f0f0f0;
}
.action-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: #999;
  padding: 8rpx 16rpx;
}
.action-btn.liked {
  color: #e53935;
}
