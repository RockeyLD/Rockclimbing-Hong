page {
  height: 100vh;
  display: flex;
  flex-direction: column;
}
.scrollarea {
  flex: 1;
  overflow-y: hidden;
}

.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}
.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #2c8f5e, #3daa73);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 500;
  margin-right: 20rpx;
}
.author-info {
  display: flex;
  flex-direction: column;
}
.author-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}
.post-time {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

.detail-content {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}
.content-text {
  display: block;
  font-size: 30rpx;
  color: #333;
  line-height: 1.7;
  margin-bottom: 24rpx;
}
.media-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 24rpx;
}
.detail-media {
  width: 100%;
  border-radius: 12rpx;
  background: #f0f0f0;
}
.location-row {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #666;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}
.loc-icon {
  margin-right: 8rpx;
}

.action-bar {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}
.action-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 28rpx;
  color: #666;
  padding: 12rpx 24rpx;
}
.action-icon {
  font-size: 32rpx;
}
.action-item.liked {
  color: #e53935;
}

/* 评论区 */
.comment-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-top: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  margin-bottom: 120rpx;
}
.comment-header {
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.comment-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}
.comment-list {
  display: flex;
  flex-direction: column;
}
.comment-item {
  display: flex;
  align-items: flex-start;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.comment-item:last-child {
  border-bottom: none;
}
.comment-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #2c8f5e, #3daa73);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  flex-shrink: 0;
  margin-right: 16rpx;
}
.comment-body {
  flex: 1;
  display: flex;
  flex-direction: column;
}
.comment-meta {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}
.comment-author {
  font-size: 26rpx;
  color: #666;
  font-weight: 500;
  margin-right: 12rpx;
}
.comment-time {
  font-size: 22rpx;
  color: #bbb;
}
.comment-content {
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
  word-break: break-all;
}
.comment-delete {
  font-size: 24rpx;
  color: #999;
  padding: 8rpx 12rpx;
  flex-shrink: 0;
}
.comment-empty {
  text-align: center;
  padding: 40rpx 0;
  font-size: 26rpx;
  color: #999;
}

/* 底部输入框 */
.comment-input-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-top: 1rpx solid #eee;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  gap: 16rpx;
  z-index: 100;
}
.comment-input {
  flex: 1;
  height: 72rpx;
  background: #f5f5f5;
  border-radius: 36rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
}
.comment-send {
  padding: 14rpx 28rpx;
  background: #ccc;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #fff;
  transition: background 0.2s;
}
.comment-send.active {
  background: #2c8f5e;
}
