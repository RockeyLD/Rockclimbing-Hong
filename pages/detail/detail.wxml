<navigation-bar title="记录详情" back="{{true}}" color="black" background="#FFF"></navigation-bar>
<scroll-view class="scrollarea safe-bottom" scroll-y type="list" wx:if="{{record}}">
  <view class="container">
    <!-- 头部 -->
    <view class="detail-header">
      <view class="flex-center">
        <view class="avatar">{{record.author ? record.author[0] : '岩'}}</view>
        <view class="author-info">
          <text class="author-name">{{record.author || '匿名'}}</text>
          <text class="post-time">{{record.date}}</text>
        </view>
      </view>
      <view class="tag tag-grade">{{record.grade}}</view>
    </view>

    <!-- 内容 -->
    <view class="detail-content">
      <text class="content-text">{{record.content}}</text>
      <view class="media-list" wx:if="{{record.mediaUrls && record.mediaUrls.length > 0}}">
        <image wx:for="{{record.mediaUrls}}" wx:for-item="url" wx:key="*this" src="{{url}}" mode="widthFix" class="detail-media" data-url="{{url}}" bindtap="previewImage" lazy-load />
      </view>
      <view class="location-row">
        <text class="loc-icon">📍</text>
        <text class="loc-text">{{record.location}}</text>
      </view>
    </view>

    <!-- 操作栏 -->
    <view class="action-bar flex-between">
      <view class="action-item {{record.isLiked ? 'liked' : ''}}" bindtap="toggleLike">
        <text class="action-icon">{{record.isLiked ? '♥' : '♡'}}</text>
        <text>{{record.likes || 0}} 赞</text>
      </view>
      <view class="action-item" bindtap="onShare">
        <text class="action-icon">↗</text>
        <text>分享</text>
      </view>
      <view class="action-item" bindtap="deleteRecord">
        <text class="action-icon">🗑</text>
        <text>删除</text>
      </view>
    </view>

    <!-- 评论区 -->
    <view class="comment-section">
      <view class="comment-header">
        <text class="comment-title">评论 ({{record.comments ? record.comments.length : 0}})</text>
      </view>

      <view class="comment-list" wx:if="{{record.comments && record.comments.length > 0}}">
        <view wx:for="{{record.comments}}" wx:key="id" class="comment-item">
          <view class="comment-avatar">{{item.author ? item.author[0] : '岩'}}</view>
          <view class="comment-body">
            <view class="comment-meta">
              <text class="comment-author">{{item.author || '匿名'}}</text>
              <text class="comment-time">{{item.createTime ? '刚刚' : ''}}</text>
            </view>
            <text class="comment-content">{{item.content}}</text>
          </view>
          <view class="comment-delete" data-id="{{item.id}}" bindtap="deleteComment">
            <text>删除</text>
          </view>
        </view>
      </view>

      <view class="comment-empty" wx:else>
        <text>还没有评论，来说两句吧~</text>
      </view>
    </view>
  </view>
</scroll-view>

<!-- 底部评论输入框 -->
<view class="comment-input-bar" wx:if="{{record}}">
  <input class="comment-input" placeholder="写评论..." value="{{commentText}}" bindinput="onCommentInput" confirm-type="send" bindconfirm="submitComment" />
  <view class="comment-send {{commentText.trim() ? 'active' : ''}}" bindtap="submitComment">
    <text>发送</text>
  </view>
</view>
