<navigation-bar title="个人记录" back="{{false}}" color="black" background="#FFF"></navigation-bar>
<scroll-view class="scrollarea safe-bottom" scroll-y type="list">
  <view class="container">
    <!-- 用户信息 -->
    <view class="user-header" bindtap="goSettings">
      <view class="user-avatar">{{userInfo.avatarText}}</view>
      <view class="user-name">{{userInfo.nickname}}</view>
      <view class="user-desc">{{userInfo.desc}}</view>
    </view>

    <!-- 数据统计 -->
    <view class="stats-grid">
      <view class="stat-box">
        <text class="stat-value">{{stats.total}}</text>
        <text class="stat-name">总记录</text>
      </view>
      <view class="stat-box">
        <text class="stat-value">{{stats.maxGrade}}</text>
        <text class="stat-name">最高难度</text>
      </view>
      <view class="stat-box">
        <text class="stat-value">{{stats.thisMonth}}</text>
        <text class="stat-name">本月</text>
      </view>
      <view class="stat-box">
        <text class="stat-value">{{stats.totalLikes}}</text>
        <text class="stat-name">获赞</text>
      </view>
    </view>

    <!-- 难度分布 -->
    <view class="card" wx:if="{{gradeDistribution.length > 0}}">
      <view class="card-title">难度分布</view>
      <view class="grade-bar-list">
        <view wx:for="{{gradeDistribution}}" wx:key="grade" class="grade-bar-item">
          <text class="grade-label">{{item.grade}}</text>
          <view class="grade-track">
            <view class="grade-fill" style="width: {{item.percent}}%"></view>
          </view>
          <text class="grade-count">{{item.count}}</text>
        </view>
      </view>
    </view>

    <!-- 我的记录列表 -->
    <view class="card">
      <view class="card-title flex-between">
        <text>我的记录</text>
        <text class="clear-btn" bindtap="clearAll">清空</text>
      </view>
      <view wx:for="{{records}}" wx:key="id" class="record-item" bindtap="goDetail" data-id="{{item.id}}">
        <image wx:if="{{item.mediaUrls.length > 0}}" src="{{item.mediaUrls[0]}}" mode="aspectFill" class="record-thumb" />
        <view wx:else class="record-thumb no-img">{{item.type === 'video' ? '▶' : '📷'}}</view>
        <view class="record-info">
          <text class="record-content">{{item.content || '无描述'}}</text>
          <view class="record-meta">
            <text class="tag tag-grade">{{item.grade}}</text>
            <text class="record-date">{{item.date}}</text>
          </view>
        </view>
        <view class="record-actions">
          <text class="delete-icon" catchtap="deleteRecord" data-id="{{item.id}}">🗑</text>
        </view>
      </view>
      <view wx:if="{{records.length === 0}}" class="empty-state">
        <text style="font-size: 60rpx;">🏔</text>
        <text>还没有记录</text>
      </view>
    </view>
  </view>
</scroll-view>
